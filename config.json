{
    "chrome_driver_path": null,
    "headless": true,
    "wait_timeout": 10,
    "action_wait": 2,
    "targets": [
        {
            "name": "SET TRI",
            "url": "https://www.set.or.th/th/market/index/tri/overview",
            "actions": [
                {
                    "type": "get",
                    "name": "date",
                    "xpath": "//div[contains(., 'ข้อมูล ณ วันที่')]/span"
                },
                {
                    "type": "click",
                    "xpath": "//span[contains(text(), 'PROPCON TRI')]"
                },
                {
                    "type": "get",
                    "name": "PF&REIT TRI",
                    "xpath": "//tr[td[contains(., 'PF&REIT TRI')]]/td[2]"
                },
                {
                    "type": "get",
                    "name": "SET50 TRI",
                    "xpath": "//tr[td[contains(., 'SET50 TRI')]]/td[2]"
                }
            ]
        }
    ]
}